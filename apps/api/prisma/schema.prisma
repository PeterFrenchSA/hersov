generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Admin
  Analyst
  ReadOnly
}

enum ContactMethodType {
  EMAIL    @map("email")
  PHONE    @map("phone")
  WEBSITE  @map("website")
  LINKEDIN @map("linkedin")
  TWITTER  @map("twitter")
  OTHER    @map("other")
}

enum EmbeddingKind {
  NOTES   @map("notes")
  PROFILE @map("profile")
  COMPANY @map("company")
}

enum ImportBatchStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
  CANCELED   @map("canceled")
}

enum ImportRowOutcome {
  INSERTED  @map("inserted")
  UPDATED   @map("updated")
  SKIPPED   @map("skipped")
  DUPLICATE @map("duplicate")
  ERROR     @map("error")
}

enum EnrichmentRunStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
  CANCELED   @map("canceled")
}

enum ChatMessageRole {
  USER      @map("user")
  ASSISTANT @map("assistant")
  TOOL      @map("tool")
  SYSTEM    @map("system")
}

enum EntityType {
  COMPANY   @map("company")
  EVENT     @map("event")
  LOCATION  @map("location")
  TOPIC     @map("topic")
  PERSON_REF @map("person_ref")
}

enum RelationshipStatus {
  SUGGESTED @map("suggested")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
}

enum ReviewKind {
  TAG          @map("tag")
  ENTITY       @map("entity")
  RELATIONSHIP @map("relationship")
}

enum ReviewStatus {
  PENDING  @map("pending")
  APPROVED @map("approved")
  REJECTED @map("rejected")
}

enum LlmRunStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String          @map("password_hash")
  role           Role            @default(ReadOnly)
  createdAt      DateTime        @default(now()) @map("created_at")
  lastLoginAt    DateTime?       @map("last_login_at")
  auditLogs      AuditLog[]      @relation("AuditActor")
  enrichmentRuns EnrichmentRun[] @relation("RunCreator")
  importBatches  ImportBatch[]   @relation("ImportCreator")
  chatThreads    ChatThread[]
  reviewQueueCreated ReviewQueue[] @relation("ReviewCreatedBy")
  reviewQueueReviewed ReviewQueue[] @relation("ReviewReviewedBy")

  @@map("users")
}

model Company {
  id          String    @id @default(cuid())
  name        String
  domain      String?
  industry    String?
  hqCity      String?   @map("hq_city")
  hqCountry   String?   @map("hq_country")
  sizeRange   String?   @map("size_range")
  linkedinUrl String?   @map("linkedin_url")
  contacts    Contact[]

  @@index([name], map: "idx_companies_name")
  @@map("companies")
}

model Contact {
  id               String             @id @default(cuid())
  firstName        String?            @map("first_name")
  lastName         String?            @map("last_name")
  fullName         String             @map("full_name")
  notesRaw         String?            @map("notes_raw")
  locationCity     String?            @map("location_city")
  locationCountry  String?            @map("location_country")
  currentTitle     String?            @map("current_title")
  currentCompanyId String?            @map("current_company_id")
  sourceImportBatchId String?         @db.Uuid @map("source_import_batch_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  lastEnrichedAt   DateTime?          @map("last_enriched_at")
  currentCompany   Company?           @relation(fields: [currentCompanyId], references: [id], onDelete: SetNull)
  sourceImportBatch ImportBatch?      @relation(fields: [sourceImportBatchId], references: [id], onDelete: SetNull)
  contactMethods   ContactMethod[]
  tags             ContactTag[]
  fieldConfidence  ContactFieldConfidence[]
  events           ContactEvent[]
  enrichmentResults EnrichmentResult[]
  embeddings       Embedding[]
  importRows       ImportRow[]
  insights         ContactInsight?
  entityMentions   ContactEntityMention[]
  relationshipsFrom Relationship[] @relation("RelationshipFromContact")
  relationshipsTo  Relationship[] @relation("RelationshipToContact")
  score            ContactScore?

  @@index([fullName], map: "idx_contacts_full_name")
  @@index([currentCompanyId], map: "idx_contacts_company_id")
  @@index([sourceImportBatchId], map: "idx_contacts_source_import_batch_id")
  @@map("contacts")
}

model ContactMethod {
  id         String            @id @default(cuid())
  contactId  String            @map("contact_id")
  type       ContactMethodType
  value      String
  isPrimary  Boolean           @default(false) @map("is_primary")
  verifiedAt DateTime?         @map("verified_at")
  source     String?
  contact    Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([value], map: "idx_contact_methods_value")
  @@index([contactId], map: "idx_contact_methods_contact_id")
  @@index([type, value], map: "idx_contact_methods_type_value")
  @@unique([contactId, type, value], map: "uq_contact_methods_contact_type_value")
  @@map("contact_methods")
}

model Tag {
  id          String       @id @default(cuid())
  name        String
  category    String
  contactTags ContactTag[]

  @@unique([name, category], map: "uq_tags_name_category")
  @@map("tags")
}

model ContactTag {
  contactId  String   @map("contact_id")
  tagId      String   @map("tag_id")
  confidence Float?
  source     String?
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("contact_tags")
}

model Event {
  id            String         @id @default(cuid())
  name          String
  year          Int?
  location      String?
  type          String?
  contactEvents ContactEvent[]

  @@map("events")
}

model ContactEvent {
  contactId   String  @map("contact_id")
  eventId     String  @map("event_id")
  contextNote String? @map("context_note")
  contact     Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  event       Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@id([contactId, eventId])
  @@map("contact_events")
}

model EnrichmentRun {
  id              String              @id @default(uuid())
  status          EnrichmentRunStatus @default(QUEUED)
  createdAt       DateTime            @default(now()) @map("created_at")
  startedAt       DateTime?          @map("started_at")
  finishedAt      DateTime?          @map("finished_at")
  createdByUserId String?            @map("created_by_user_id")
  configJson      Json?              @map("config_json")
  statsJson       Json?              @map("stats_json")
  totalTargets    Int                @default(0) @map("total_targets")
  processedTargets Int               @default(0) @map("processed_targets")
  updatedContacts Int                @default(0) @map("updated_contacts")
  skippedContacts Int                @default(0) @map("skipped_contacts")
  errorCount      Int                @default(0) @map("error_count")
  errorSampleJson Json?              @map("error_sample_json")
  createdByUser   User?              @relation("RunCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  results         EnrichmentResult[]

  @@index([status, createdAt], map: "idx_enrichment_runs_status_created_at")
  @@index([createdByUserId], map: "idx_enrichment_runs_created_by")
  @@map("enrichment_runs")
}

model EnrichmentResult {
  id          String        @id @default(cuid())
  runId       String        @map("run_id")
  contactId   String        @map("contact_id")
  field       String
  oldValue    String?       @map("old_value")
  newValue    String?       @map("new_value")
  confidence  Float?
  provider    String
  providerRef String?       @map("provider_ref")
  evidenceUrl String?       @map("evidence_url")
  createdAt   DateTime      @default(now()) @map("created_at")
  run         EnrichmentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt], map: "idx_enrichment_results_run_created_at")
  @@index([contactId, createdAt], map: "idx_enrichment_results_contact_created_at")
  @@map("enrichment_results")
}

model ContactFieldConfidence {
  contactId   String   @map("contact_id")
  field       String
  confidence  Float
  provider    String
  updatedAt   DateTime @updatedAt @map("updated_at")
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([contactId, field])
  @@index([updatedAt], map: "idx_contact_field_confidence_updated_at")
  @@map("contact_field_confidence")
}

model ContactInsight {
  contactId          String   @id @map("contact_id")
  notesHash          String   @map("notes_hash")
  insightsJson       Json     @map("insights_json")
  model              String
  promptVersion      String   @map("prompt_version")
  confidenceOverall  Float    @default(0) @map("confidence_overall")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  contact            Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([updatedAt], map: "idx_contact_insights_updated_at")
  @@map("contact_insights")
}

model Entity {
  id            String                 @id @default(cuid())
  type          EntityType
  canonicalName String                 @map("canonical_name")
  externalUrl   String?                @map("external_url")
  createdAt     DateTime               @default(now()) @map("created_at")
  aliases       EntityAlias[]
  mentions      ContactEntityMention[]
  relationships Relationship[]

  @@unique([type, canonicalName], map: "uq_entities_type_canonical_name")
  @@index([type, canonicalName], map: "idx_entities_type_canonical_name")
  @@map("entities")
}

model EntityAlias {
  id        String   @id @default(cuid())
  entityId  String   @map("entity_id")
  alias     String
  createdAt DateTime @default(now()) @map("created_at")
  entity    Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([alias], map: "uq_entity_aliases_alias")
  @@index([entityId], map: "idx_entity_aliases_entity_id")
  @@map("entity_aliases")
}

model ContactEntityMention {
  id              String   @id @default(cuid())
  contactId       String   @map("contact_id")
  entityId        String   @map("entity_id")
  source          String
  evidenceSnippet String   @map("evidence_snippet")
  confidence      Float
  createdAt       DateTime @default(now()) @map("created_at")
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([contactId, entityId], map: "uq_contact_entity_mentions_contact_entity")
  @@index([contactId], map: "idx_contact_entity_mentions_contact_id")
  @@index([entityId], map: "idx_contact_entity_mentions_entity_id")
  @@map("contact_entity_mentions")
}

model Relationship {
  id              String             @id @default(cuid())
  fromContactId   String             @map("from_contact_id")
  toContactId     String?            @map("to_contact_id")
  type            String
  entityId        String?            @map("entity_id")
  evidenceSnippet String             @map("evidence_snippet")
  confidence      Float
  status          RelationshipStatus @default(SUGGESTED)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  fromContact     Contact            @relation("RelationshipFromContact", fields: [fromContactId], references: [id], onDelete: Cascade)
  toContact       Contact?           @relation("RelationshipToContact", fields: [toContactId], references: [id], onDelete: SetNull)
  entity          Entity?            @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@index([fromContactId, status], map: "idx_relationships_from_status")
  @@index([toContactId, status], map: "idx_relationships_to_status")
  @@index([entityId], map: "idx_relationships_entity_id")
  @@index([status, createdAt], map: "idx_relationships_status_created_at")
  @@map("relationships")
}

model ReviewQueue {
  id               String       @id @default(cuid())
  kind             ReviewKind
  payloadJson      Json         @map("payload_json")
  status           ReviewStatus @default(PENDING)
  createdByUserId  String       @map("created_by_user_id")
  reviewedByUserId String?      @map("reviewed_by_user_id")
  reviewedAt       DateTime?    @map("reviewed_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  createdByUser    User         @relation("ReviewCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  reviewedByUser   User?        @relation("ReviewReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, kind, createdAt], map: "idx_review_queue_status_kind_created_at")
  @@index([createdByUserId], map: "idx_review_queue_created_by")
  @@index([reviewedByUserId], map: "idx_review_queue_reviewed_by")
  @@map("review_queue")
}

model LlmPromptVersion {
  id        String   @id @default(cuid())
  name      String
  version   String
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([name, version], map: "uq_llm_prompt_versions_name_version")
  @@index([createdAt], map: "idx_llm_prompt_versions_created_at")
  @@map("llm_prompt_versions")
}

model LlmRun {
  id            String       @id @default(cuid())
  purpose       String
  model         String
  promptVersion String       @map("prompt_version")
  inputHash     String       @map("input_hash")
  status        LlmRunStatus
  tokensIn      Int?         @map("tokens_in")
  tokensOut     Int?         @map("tokens_out")
  latencyMs     Int?         @map("latency_ms")
  errorJson     Json?        @map("error_json")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@index([purpose, createdAt], map: "idx_llm_runs_purpose_created_at")
  @@index([status, createdAt], map: "idx_llm_runs_status_created_at")
  @@map("llm_runs")
}

model ContactScore {
  contactId      String   @id @map("contact_id")
  connectorScore Float    @map("connector_score")
  influenceScore Float?   @map("influence_score")
  computedAt     DateTime @map("computed_at")
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([connectorScore], map: "idx_contact_scores_connector_score")
  @@index([computedAt], map: "idx_contact_scores_computed_at")
  @@map("contact_scores")
}

model Embedding {
  id        String              @id @default(cuid())
  contactId String              @map("contact_id")
  kind      EmbeddingKind
  model     String              @default("legacy")
  dims      Int                 @default(0)
  hash      String              @default("")
  vector    Unsupported("vector")?
  text      String?
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  contact   Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, kind], map: "uq_embeddings_contact_kind")
  @@index([contactId, kind], map: "idx_embeddings_contact_kind")
  @@map("embeddings")
}

model ChatThread {
  id        String        @id @default(cuid())
  userId    String        @map("user_id")
  title     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt], map: "idx_chat_threads_user_updated_at")
  @@map("chat_threads")
}

model ChatMessage {
  id          String          @id @default(cuid())
  threadId    String          @map("thread_id")
  role        ChatMessageRole
  contentText String          @map("content_text")
  toolName    String?         @map("tool_name")
  toolJson    Json?           @map("tool_json")
  createdAt   DateTime        @default(now()) @map("created_at")
  thread      ChatThread      @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt], map: "idx_chat_messages_thread_created_at")
  @@map("chat_messages")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorUserId String? @map("actor_user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  metaJson   Json?    @map("meta_json")
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")
  actorUser  User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([action], map: "idx_audit_logs_action")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@map("audit_logs")
}

model ImportBatch {
  id               String            @id @db.Uuid
  filename         String
  originalHeadersJson Json           @map("original_headers_json")
  columnMappingJson Json?            @map("column_mapping_json")
  status           ImportBatchStatus @default(QUEUED)
  createdByUserId  String?           @map("created_by_user_id")
  createdAt        DateTime          @default(now()) @map("created_at")
  startedAt        DateTime?         @map("started_at")
  finishedAt       DateTime?         @map("finished_at")
  totalRows        Int               @default(0) @map("total_rows")
  processedRows    Int               @default(0) @map("processed_rows")
  insertedCount    Int               @default(0) @map("inserted_count")
  updatedCount     Int               @default(0) @map("updated_count")
  skippedCount     Int               @default(0) @map("skipped_count")
  duplicateCount   Int               @default(0) @map("duplicate_count")
  errorCount       Int               @default(0) @map("error_count")
  errorSampleJson  Json?             @map("error_sample_json")
  createdByUser    User?             @relation("ImportCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  rows             ImportRow[]
  contacts         Contact[]

  @@index([status], map: "idx_import_batches_status")
  @@index([createdByUserId], map: "idx_import_batches_created_by_user_id")
  @@map("import_batches")
}

model ImportRow {
  id             BigInt           @id @default(autoincrement())
  batchId        String           @db.Uuid @map("batch_id")
  rowIndex       Int              @map("row_index")
  rawJson        Json?            @map("raw_json")
  normalizedJson Json?            @map("normalized_json")
  outcome        ImportRowOutcome
  contactId      String?          @map("contact_id")
  errorMessage   String?          @map("error_message")
  createdAt      DateTime         @default(now()) @map("created_at")
  batch          ImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)
  contact        Contact?         @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([batchId], map: "idx_import_rows_batch_id")
  @@index([batchId, rowIndex], map: "idx_import_rows_batch_id_row_index")
  @@index([batchId, outcome], map: "idx_import_rows_batch_id_outcome")
  @@map("import_rows")
}
