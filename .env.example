# Domain / URLs
APP_DOMAIN=crm.example.com
APP_BASE_URL=https://crm.example.com
LETSENCRYPT_EMAIL=admin@example.com

# Secrets
SESSION_SECRET=replace_me_long_random
ENCRYPTION_KEY=replace_me_32_bytes_base64_or_hex
OPENAI_API_KEY=replace_me

# Postgres
POSTGRES_DB=minicrm
POSTGRES_USER=minicrm
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql://minicrm:replace_me@postgres:5432/minicrm?schema=public

# Redis / Queue
REDIS_URL=redis://redis:6379
TRUST_PROXY=1

# Optional provider keys
APOLLO_API_KEY=
CLEARBIT_API_KEY=
PDL_API_KEY=
ZEROBOUNCE_API_KEY=

# Optional bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
